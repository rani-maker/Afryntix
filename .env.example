# ==========================================
# AFRYNTIX - Variables d'environnement
# ==========================================

# Database (Supabase PostgreSQL)
# Connexion poolée via PgBouncer — pour l'app en runtime (port 6543)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Connexion directe — pour prisma db push / migrate (port 5432)
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# WhatsApp — UltraMsg (provider actif)
# Créer un compte sur https://ultramsg.com → New Instance → copier Instance ID et Token
ULTRAMSG_INSTANCE_ID="instance12345"
ULTRAMSG_TOKEN="your_ultramsg_token_here"

# WhatsApp — Twilio (réservé, activer après validation Business Meta)
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="your_auth_token_here"
# TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Admin par défaut (pour le seed)
DEFAULT_ADMIN_EMAIL="admin@afryntix.com"
DEFAULT_ADMIN_PASSWORD="ChangeMeNow!2026"
DEFAULT_ADMIN_NAME="Administrateur AFRYNTIX"
DEFAULT_ADMIN_PHONE="+2250700000000"

# Upload (local par défaut, S3 optionnel)
UPLOAD_DIR="./public/uploads"

# Supabase Storage — pour uploads KYC partenaires (pièce d'identité, contrats signés)
# Récupérer dans Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="ey..."           # clé publique (anon)
SUPABASE_SERVICE_ROLE_KEY="ey..."               # clé SECRÈTE service_role (jamais exposer côté client)
# Créer le bucket "partner-kyc" en mode PRIVÉ dans Storage avant utilisation

# App
NEXT_PUBLIC_APP_NAME="AFRYNTIX"
NEXT_PUBLIC_COMPANY_TAGLINE="Transport & Logistique Chine - Afrique de l'Ouest"
# URL publique utilisée pour les QR codes d'étiquettes, les liens WhatsApp (suivi, retrait)
# et les invitations staff. EN PROD : remplacer par le domaine définitif (sans slash final).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
